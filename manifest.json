{
  "manifest_version": 3,
  "name": "Goal before Scroll (GBS)",
  "version": "1.0.0",
  "description": "Stay focused on your goals using local funny memes. Work offline and protect your productivity.",
  "icons": {
    "16": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/images/*",
        "images/logo.png",
        "data/presets.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
